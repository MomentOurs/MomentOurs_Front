{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "target": "es2016",
    "module": "esnext",
    "jsx": "react-native", 
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["@types/react", "@types/react-native", "@env"]
  },
  "include": ["env.d.ts", "src", "declarations.d.ts"]
}
